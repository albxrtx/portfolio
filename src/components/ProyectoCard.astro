---
import Etiqueta from "./Etiqueta.astro";

interface Props {
  url: string;
  demo?: string;
  portada: string;
  nombre: string;
  descripcion: string;
  etiquetas: string[];
}

const { url, demo, portada, nombre, descripcion, etiquetas } = Astro.props;
---

<div
  class="bg-primary-bg border border-primary-border shadow-md shadow-primary-shadow lg:w-full w-70 h-full flex flex-col items-start justify-start rounded-2xl overflow-hidden"
>
  <div class="w-full">
    <img src={portada} class="w-full h-30 lg:h-40 object-cover" alt="" />
  </div>
  <div class="px-4 py-2 flex flex-col h-full">
    <h2 class="font-semibold text-primary-text">{nombre}</h2>
    <div class="flex flex-col gap-2 justify-around h-full">
      <p class="text-gray-600 text-xs lg:text-sm">
        {descripcion}
      </p>
      <div class="flex flex-row flex-wrap gap-2">
        {etiquetas.map((etiqueta) => <Etiqueta nombre={etiqueta} />)}
      </div>
      <div
        class="flex flex-col lg:flex-row lg:items-center gap-2 text-xs lg:text-sm text-white w-full"
      >
        <a
          href={url}
          target="_blank"
          class="flex items-center justify-center gap-1 bg-blue-500 py-1 lg:py-2 px-3 lg:px-6 rounded-2xl hover:bg-accent-blue-hover hover:border-accent-blue-hover w-full lg:w-auto"
        >
          <svg class="size-4 lg:size-5 fill-white">
            <use xlink:href={`#github`}></use>
          </svg>
          Ver repositorio
        </a>
        {
          demo && (
            <a
              href={demo}
              target="_blank"
              class="flex items-center justify-center gap-1 bg-blue-500 py-1 lg:py-2 px-3 lg:px-6 rounded-2xl hover:bg-accent-blue-hover hover:border-accent-blue-hover w-full lg:w-auto"
            >
              <svg class="size-4 lg:size-5 fill-white">
                <use xlink:href={`#link`} />
              </svg>
              Probar Demo
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>
